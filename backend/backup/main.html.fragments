        async function openProductPage(product) {
            currentProduct = product;
            const overlay = document.getElementById('product-modal-overlay');
            const contentEl = document.getElementById('product-view-content');
            const heroSection = overlay.querySelector('.hero-section');

            heroSection.style.backgroundImage = `url('${product.image || 'https://via.placeholder.com/1600x400?text=No+Image'}')`;

            const isInCart = cartState.some(item => item.id == product.id && item.product_section == product.productSection);
            const isPurchased = product.isPurchased;

            // Open popup immediately
            let html = '';
            if (product.type === 'Course' && isPurchased) {
                html = buildLoadingView(product);
            } else if (product.type === 'Course') {
                html = buildPurchaseView(product, isInCart);
            } else if (product.type === 'Indicator') {
                html = buildIndicatorView(product, isInCart, isPurchased);
            } else if (product.type === 'Bot') {
                html = buildBotView(product, isInCart, isPurchased);
            }

            contentEl.innerHTML = html;

            // Move Go to Course button to fixed bottom bar
            fixGoCourseButton();

            // Description expand/collapse
            const desc = contentEl.querySelector('.pv-description');
            if (desc) {
                desc.addEventListener('click', () => desc.classList.toggle('expanded'));
            }

            overlay.classList.remove('hidden');
            document.body.classList.add('product-modal-open');
            void overlay.offsetWidth;
            overlay.classList.remove('opacity-0');
            overlay.classList.add('opacity-100');
            const content = document.getElementById('product-modal-content');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');

            // Fetch enrollment status in background for purchased courses
            if (product.type === 'Course' && isPurchased) {
                // Force browser to paint the spinner before fetching
                await new Promise(r => requestAnimationFrame(r));

                enrollmentStatus = null;
                try {
                    const token = localStorage.getItem('token');
                    if (token) {
                        const res = await fetch(`/api/enrollment-status/${product.id}`, {
                            headers: { 'Authorization': 'Bearer ' + token }
                        });
                        if (res.ok) {
                            enrollmentStatus = await res.json();
                        } else {
                            throw new Error('Failed to fetch');
                        }
                    } else {
                        throw new Error('No token');
                    }
                } catch (e) {
                    console.error("Failed to fetch enrollment status:", e);
                    const timelineContainer = document.getElementById('pv-timeline-container');
                    if (timelineContainer) {
                        timelineContainer.className = 'pv-timeline pv-timeline-error';
                        timelineContainer.innerHTML = `
                            <div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                Failed to load timeline
                            </div>
                        `;
                    }
                    return;
                }
                // Re-render timeline with actual data
                const timelineHtml = buildTimelineOnly(product);
                const timelineContainer = document.getElementById('pv-timeline-container');
                if (timelineContainer) {
                    timelineContainer.outerHTML = timelineHtml;
                }
                // Update progress bar
                const progressPct = (enrollmentStatus && enrollmentStatus.progress !== undefined) ? enrollmentStatus.progress : 0;
                const progressSection = contentEl.querySelector('.pv-progress-section');
                if (progressSection) {
                    progressSection.outerHTML = `
                        <div class="pv-progress-section">
                            <div class="pv-progress-header">
                                <span>Progress</span>
                                <span>${progressPct}%</span>
                            </div>
                            <div class="pv-progress-track">
                                <div class="pv-progress-fill" style="width: ${progressPct}%"></div>
                            </div>
                        </div>
                    `;
                }
            }
        }

