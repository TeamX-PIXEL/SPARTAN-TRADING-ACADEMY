        function handleCardClick(event, cardElement) {
            if (event.target.closest('button')) return;

            const product = {
                id: cardElement.dataset.id,
                title: cardElement.dataset.title,
                description: cardElement.dataset.description,
                price: parseFloat(cardElement.dataset.price),
                image: cardElement.dataset.image,
                type: cardElement.dataset.type,
                productSection: parseInt(cardElement.dataset.section),
                isPurchased: cardElement.dataset.purchased === 'true',
                details: {}
            };

            if (product.type === 'Course') {
                let chapters = [];
                if (cardElement.dataset.chapters) {
                    chapters = cardElement.dataset.chapters.split('|').filter(Boolean).map(entry => {
                        const [idx, ...rest] = entry.split(':');
                        return { chapter_index: parseInt(idx), title: rest.join(':') };
                    });
                }
                product.details = {
                    scheduled: cardElement.dataset.scheduled,
                    duration: cardElement.dataset.duration,
                    link: cardElement.dataset.link,
                    chapters: chapters
                };
            }

            openProductPage(product);
        }

