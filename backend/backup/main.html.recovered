                                </div>
                                <div id="password-save-status" class="hidden text-sm font-semibold"></div>
                                <button onclick="savePassword()" class="self-start px-6 py-2.5 bg-gray-900 text-white font-bold rounded-xl hover:bg-gray-800 transition-all text-sm flex items-center gap-2">
                                    <i class="ph ph-lock-key text-lg"></i> Update Password
                                </button>
                            </div>
                        </div>

                        <!-- Logout Section -->
                        <button onclick="logout()" class="w-full bg-red-50 rounded-[1.75rem] p-5 flex items-center justify-between hover:bg-red-100 transition-colors text-left">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl bg-red-100 flex items-center justify-center text-red-500">
                                    <i class="ph ph-sign-out text-2xl"></i>
                                </div>
                                <div>
                                    <p class="text-[15px] font-bold text-red-600">Log Out</p>
                                    <p class="text-xs text-red-400 mt-0.5">Sign out of your account</p>
                                </div>
                            </div>
                            <i class="ph ph-caret-right text-xl text-red-300"></i>
                        </button>
                    `}
                </div>
            `;

            skeletonCards.classList.add('hidden');
            actualCards.classList.remove('hidden');

            if (highlightField) {
                history.replaceState(null, '', '/settings/account');
            }
        }

