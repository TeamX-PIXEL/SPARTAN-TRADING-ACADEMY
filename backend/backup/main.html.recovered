                        const cardHtml = `
                            <div class="nft-card" data-id="${indicator.product_uuid}" data-title="${indicator.indicator_name.replace(/"/g, '&quot;')}" data-description="${(indicator.indicator_description || '').replace(/"/g, '&quot;')}" data-price="${indicator.indicator_price}" data-image="${indicator.showcase_image || 'https://via.placeholder.com/150'}" data-type="Indicator" data-section="2" data-purchased="${isPurchased}" onclick="handleCardClick(event, this)">
                                <div class="image-container">
                                    <img src="${indicator.showcase_image || 'https://via.placeholder.com/300x200?text=No+Image'}" alt="Indicator Thumbnail" class="nft-image">
                                    <button class="like-btn" onclick="toggleLike(this, event)" aria-label="Like">
                                        <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                                        </svg>
                                    </button>
                                    ${priceTagHtml}
                                </div>
                                <div class="info-section">
                                    <div class="text-content">
                                        <h3 class="title" title="${indicator.indicator_name}">${indicator.indicator_name}</h3>
                                        <p class="description" title="${indicator.indicator_description}">${indicator.indicator_description || 'No description provided.'}</p>
                                    </div>
                                    ${actionBtnHtml}
                                </div>
                            </div>
                        `;
                        actualCards.innerHTML += cardHtml;
                    });

                    hasMoreIndicators = indicators.length === indicatorLimit;
                }
            } catch (error) {
                if (!append) {
                    actualCards.innerHTML = '<div class="col-span-full text-center py-10 text-red-500 font-bold text-sm bg-red-50 rounded-2xl border border-red-100">Failed to load indicators. Is the backend running?</div>';
                }
            } finally {
                if (!append) {
                    skeletonCards.classList.add('hidden');
                    actualCards.classList.remove('hidden');
                }
                isLoading = false;
            }
        }

