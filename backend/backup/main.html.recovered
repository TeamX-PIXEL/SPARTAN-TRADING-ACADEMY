                    ` : `
                        <!-- Profile Section -->
                        <div class="bg-white rounded-[1.75rem] p-6 shadow-card">
                            ${highlightField ? `<div class="flex items-center gap-2 p-3 mb-4 bg-red-50 border border-red-200 rounded-xl text-sm font-semibold text-red-600"><i class="ph ph-warning-circle text-lg"></i> Please fill in the highlighted field below before purchasing.</div>` : ''}
