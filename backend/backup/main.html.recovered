                                        <label class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Email</label>
                                        <input type="text" value="${user ? user.email : ''}" disabled class="w-full h-11 px-4 bg-gray-50 border border-gray-100 rounded-xl text-sm font-semibold text-gray-400 cursor-not-allowed">
                                    </div>
                                    <div>
                                        <label class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">User ID</label>
                                        <input type="text" value="${user ? user.UserID : ''}" disabled class="w-full h-11 px-4 bg-gray-50 border border-gray-100 rounded-xl text-sm font-semibold text-gray-400 cursor-not-allowed">
