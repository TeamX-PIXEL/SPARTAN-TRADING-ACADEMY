                                        <input id="setting-username" type="text" value="${user ? user.UserName : ''}" class="w-full h-11 px-4 bg-gray-50 border border-gray-100 rounded-xl text-sm font-semibold text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand/30 focus:bg-white transition-all" placeholder="Your name">
