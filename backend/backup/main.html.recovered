                                <p class="text-xs text-gray-500 mt-0.5">Show more items per screen</p>
                            </div>
                            <button id="toggle-compact" onclick="togglePreference(this, 'compact')" class="w-12 h-7 rounded-full bg-gray-200 relative transition-colors duration-200">
