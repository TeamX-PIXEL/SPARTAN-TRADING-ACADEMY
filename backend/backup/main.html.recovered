        function togglePreference(btn, key) {
            const isOn = btn.classList.contains('bg-brand');
            const knob = btn.querySelector('span');
            if (isOn) {
                btn.classList.remove('bg-brand');
                btn.classList.add('bg-gray-200');
                knob.classList.remove('right-0.5');
                knob.classList.add('left-0.5');
            } else {
                btn.classList.remove('bg-gray-200');
                btn.classList.add('bg-brand');
                knob.classList.remove('left-0.5');
                knob.classList.add('right-0.5');
            }
            localStorage.setItem('pref_' + key, !isOn);
        }

        // --- TOAST NOTIFICATION SYSTEM ---
        function showToast(message, type = 'success', duration = 4000) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            const icon = type === 'success'
                ? '<i class="ph ph-check-circle text-xl"></i>'
                : '<i class="ph ph-warning-circle text-xl"></i>';
            toast.innerHTML = `
                <span class="toast-icon">${icon}</span>
                <span class="toast-msg">${message}</span>
                <button class="toast-close" onclick="this.parentElement.classList.add('hide'); setTimeout(() => this.parentElement.remove(), 300);">
                    <i class="ph ph-x text-sm"></i>
                </button>
            `;
            container.appendChild(toast);
            requestAnimationFrame(() => requestAnimationFrame(() => toast.classList.add('show')));
            setTimeout(() => {
                toast.classList.add('hide');
                setTimeout(() => toast.remove(), 300);
            }, duration);
        }

        async function saveProfile() {
            const token = localStorage.getItem('token');
            if (!token) return;

            const username = document.getElementById('setting-username').value.trim();
            const tvid = document.getElementById('setting-tvid').value.trim();
            const statusEl = document.getElementById('profile-save-status');

            try {
                const response = await fetch('/users/me', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify({ UserName: username, tvid: tvid })
                });

                if (response.ok) {
                    statusEl.innerText = 'Profile saved successfully!';
                    statusEl.className = 'text-sm font-semibold text-green-600';
                    statusEl.classList.remove('hidden');
                    const nameDisplay = document.getElementById('auth-display-name');
                    if (nameDisplay) nameDisplay.innerText = username;
                    setTimeout(() => statusEl.classList.add('hidden'), 3000);
                } else {
                    const data = await response.json();
                    statusEl.innerText = data.detail || 'Failed to save profile.';
                    statusEl.className = 'text-sm font-semibold text-red-500';
                    statusEl.classList.remove('hidden');
                }
            } catch (err) {
                statusEl.innerText = 'Network error. Please try again.';
                statusEl.className = 'text-sm font-semibold text-red-500';
                statusEl.classList.remove('hidden');
            }
        }

        async function savePassword() {
            const token = localStorage.getItem('token');
            if (!token) return;

            const current = document.getElementById('setting-current-password').value;
            const newPass = document.getElementById('setting-new-password').value;
            const confirm = document.getElementById('setting-confirm-password').value;
            const statusEl = document.getElementById('password-save-status');

            if (!current || !newPass || !confirm) {
                statusEl.innerText = 'Please fill in all fields.';
                statusEl.className = 'text-sm font-semibold text-red-500';
                statusEl.classList.remove('hidden');
                return;
            }
            if (newPass !== confirm) {
                statusEl.innerText = 'New passwords do not match.';
                statusEl.className = 'text-sm font-semibold text-red-500';
                statusEl.classList.remove('hidden');
                return;
            }
            if (newPass.length < 6) {
                statusEl.innerText = 'Password must be at least 6 characters.';
                statusEl.className = 'text-sm font-semibold text-red-500';
                statusEl.classList.remove('hidden');
                return;
            }

            try {
                const response = await fetch('/users/me/password', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify({ current_password: current, new_password: newPass })
                });

                if (response.ok) {
                    document.getElementById('setting-current-password').value = '';
                    document.getElementById('setting-new-password').value = '';
                    document.getElementById('setting-confirm-password').value = '';
                    statusEl.innerText = 'Password updated successfully!';
                    statusEl.className = 'text-sm font-semibold text-green-600';
                    statusEl.classList.remove('hidden');
                    setTimeout(() => statusEl.classList.add('hidden'), 3000);
                } else {
                    const data = await response.json();
                    statusEl.innerText = data.detail || 'Failed to update password.';
                    statusEl.className = 'text-sm font-semibold text-red-500';
                    statusEl.classList.remove('hidden');
                }
            } catch (err) {
                statusEl.innerText = 'Network error. Please try again.';
                statusEl.className = 'text-sm font-semibold text-red-500';
                statusEl.classList.remove('hidden');
            }
        }

async function processCheckout(btnElement) {
    const token = localStorage.getItem('token');
    if (!token) {
        goToLogin();
        return;
    }

    if (cartState.length === 0) return;

    const allCheckoutBtns = document.querySelectorAll('.checkout-btn');
    allCheckoutBtns.forEach(btn => {
        btn.innerText = "Processing...";
        btn.disabled = true;
    });

    let purchaseCount = 0;
    let failedItems = [];

    try {
        for (const item of cartState) {
            const response = await fetch('/purchase', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + token
                },
                body: JSON.stringify({ 
                    product_section: parseInt(item.product_section),
                    product_uuid: item.id, 
                    cost: item.price 
                })
            });
            if (response.ok) {
                if (item.product_section == 1) {
                    purchasedCourseIds.push(item.id);
                } else if (item.product_section == 2) {
                    purchasedIndicatorIds.push(item.id);
                } else if (item.product_section == 3) {
                    purchasedBotIds.push(item.id);
                }
                purchaseCount++;
            } else {
                const errData = await response.json().catch(() => ({}));
                const errMsg = errData.detail || 'Purchase failed';
                if (errMsg.toLowerCase().includes('tvid')) {
                    showToast('TradingView Username is required. Redirecting to settings...', 'error', 4000);
                    cartState = [];
                    saveCart();
                    renderCart();
                    allCheckoutBtns.forEach(btn => {
                        btn.innerHTML = `<i class="ph ph-credit-card text-lg"></i> Checkout`;
                        btn.disabled = false;
                    });
                    history.pushState({}, '', '/settings/account?error=tvid');
                    loadSection('settings', 'account', 'tvid');
                    return;
                }
                failedItems.push(item.title);
            }
        }
        
        if (purchaseCount > 0 && failedItems.length === 0) {
            showToast(`Purchase successful! You bought ${purchaseCount} item${purchaseCount > 1 ? 's' : ''}.`, 'success', 4000);
        } else if (purchaseCount > 0 && failedItems.length > 0) {
            showToast(`Partial success: ${purchaseCount} purchased, ${failedItems.length} failed.`, 'error', 5000);
        } else {
            showToast('Purchase failed. Please try again.', 'error', 4000);
        }

        cartState = [];
        saveCart();
        renderCart();
        renderLibrary();
        
        const isIndicatorsTab = document.querySelector('.nav-item.active').innerText.includes("Indicators");
        const isAlertsTab = document.querySelector('.nav-item.active').innerText.includes("Alerts");
        if (isIndicatorsTab) {
            fetchIndicators();
        } else if (isAlertsTab) {
            fetchBots();
        } else {
            fetchCourses();
        }

        // Refresh product view if it's open
        if (currentProduct && currentProduct.isPurchased === false) {
            currentProduct.isPurchased = true;
            if (currentProduct.productSection === 1) {
                purchasedCourseIds.push(parseInt(currentProduct.id));
            } else if (currentProduct.productSection === 2) {
                purchasedIndicatorIds.push(parseInt(currentProduct.id));
            } else if (currentProduct.productSection === 3) {
                purchasedBotIds.push(parseInt(currentProduct.id));
            }
            openProductPage(currentProduct);
        }
        
        const targetTab = document.querySelector(`#cart-modal-content .tab-library`);
        if (targetTab) switchSlide('library', targetTab);

    } catch (err) {
        showToast('Network error. Is the server running?', 'error', 4000);
    } finally {
        allCheckoutBtns.forEach(btn => {
            btn.innerHTML = `<i class="ph ph-credit-card text-lg"></i> Checkout`;
            btn.disabled = false;
        });
    }
}


        // Live Countdown Math
        function forceTimerUpdate() {
            document.querySelectorAll('.countdown-wrapper').forEach(wrapper => {
                let dateStr = wrapper.dataset.scheduled;
                if (!dateStr || dateStr === 'null' || dateStr === 'undefined') {
                    wrapper.querySelector('.timer-text').innerText = 'Not scheduled';
                    return;
                }
                // Treat naive datetime strings as local time (no 'Z' suffix)

                const scheduledTime = new Date(dateStr).getTime();
                if (isNaN(scheduledTime)) {
                    wrapper.querySelector('.timer-text').innerText = 'Invalid date';
                    return;
                }
                const durationStr = wrapper.dataset.duration || "2 hours";
                
                let durationMs = 2 * 60 * 60 * 1000; 
                const match = durationStr.match(/([\d.]+)/); 
                if (match) {
                    const val = parseFloat(match[1]);
                    if (durationStr.toLowerCase().includes('min')) {
                        durationMs = val * 60 * 1000; 
                    } else {
                        durationMs = val * 60 * 60 * 1000; 
                    }
                }

                const endTime = scheduledTime + durationMs;
                const now = new Date().getTime();
                
                const timerText = wrapper.querySelector('.timer-text');
                const icon = wrapper.querySelector('i');
                const card = wrapper.closest('.nft-card');
                const actionBtn = card ? card.querySelector('.join-btn') : null;

                if (now >= scheduledTime && now <= endTime) {
                    timerText.innerText = "Live Now!";
                    timerText.classList.remove('text-brand', 'text-gray-500');
                    timerText.classList.add('text-green-600');
                    if (icon) icon.className = "ph ph-clock text-green-600 font-bold";

                    if (actionBtn && actionBtn.classList.contains('cursor-not-allowed')) {
                        actionBtn.className = "cart-btn added ml-2 join-btn bg-green-500 border-green-500 hover:bg-green-600 cursor-pointer shadow-md transition-all";
                        actionBtn.innerHTML = `<i class="ph ph-play-circle text-xl text-white"></i>`;
                        actionBtn.onclick = (e) => {
                            e.stopPropagation(); 
                            window.open(actionBtn.dataset.link, '_blank');
                        };
                    }
                } else if (now > endTime) {
                    timerText.innerText = "Not yet scheduled";
                    timerText.classList.remove('text-brand', 'text-green-600');
                    timerText.classList.add('text-gray-500');
                    if (icon) icon.className = "ph ph-calendar-blank text-gray-500 font-bold";
                    
                    if (actionBtn) {
                        actionBtn.className = "cart-btn ml-2 join-btn opacity-40 bg-gray-200 cursor-not-allowed pointer-events-none";
                        actionBtn.innerHTML = `<i class="ph ph-play-circle text-xl text-gray-600"></i>`;
                        actionBtn.onclick = null; 
                    }
                } else {
                    const diff = scheduledTime - now;
                    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                    const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                    const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                    const s = Math.floor((diff % (1000 * 60)) / 1000);
                    
                    timerText.classList.remove('text-green-600', 'text-gray-500');
                    timerText.classList.add('text-brand');
                    if (icon) icon.className = "ph ph-clock text-brand font-bold";

                    if (d > 0) timerText.innerText = `Starts in ${d}d ${h}h`;
                    else timerText.innerText = `Starts in ${h}h ${m}m ${s}s`;
                }
            });
        }
        
        function startCountdownTimer() {
            setInterval(forceTimerUpdate, 1000);
        }
// Cart Utility Functions
function toggleCart(button, event, id, title, price, image, itemType, productSection) {
    event.stopPropagation(); 
    // Check both ID and section to prevent conflicts
    const existingIndex = cartState.findIndex(item => item.id == id && item.product_section == productSection);

    if (existingIndex > -1) {
        cartState.splice(existingIndex, 1);
        button.classList.remove('added');
    } else {
        // Now storing type and product_section in the cart state
        cartState.push({ id, title, price, image, type: itemType, product_section: productSection });
        button.classList.add('added');
    }
    saveCart(); 
    button.style.transform = 'scale(0.8)';
    setTimeout(() => { button.style.transform = 'scale(1)'; }, 150);
    renderCart();
}

function removeFromCart(id, productSection) {
    // Filter out the exact item type
    cartState = cartState.filter(item => !(item.id == id && item.product_section == productSection));
    saveCart(); 
    const relatedCard = document.querySelector(`.nft-card[data-id="${id}"]`);
    if (relatedCard) {
        const cartBtn = relatedCard.querySelector('.add-to-cart-btn');
        if (cartBtn) cartBtn.classList.remove('added');
    }
    renderCart();
}


function renderCart() {
    const containers = document.querySelectorAll('.cart-items-container');
    const totalElements = document.querySelectorAll('.cart-total');
    const tabElements = document.querySelectorAll('.tab-cart');
    const headerBadge = document.getElementById('header-cart-badge');

    tabElements.forEach(el => el.innerText = `Cart (${cartState.length})`);

    if (cartState.length > 0) {
        headerBadge.innerText = cartState.length;
        headerBadge.classList.remove('hidden');
    } else {
        headerBadge.classList.add('hidden');
    }

    let htmlString = '';
    let currentTotal = 0;

    if (cartState.length === 0) {
        htmlString = `
            <div class="flex flex-col items-center justify-center text-center h-full py-10 opacity-60">
                <i class="ph ph-shopping-cart text-4xl mb-2 text-gray-400"></i>
                <p class="text-sm font-medium text-gray-500">Your cart is empty.</p>
            </div>`;
    } else {
        cartState.forEach(item => {
            currentTotal += item.price;
            htmlString += `
                <div class="flex items-center justify-between p-3.5 bg-[#F8F9FB] border border-gray-100 rounded-2xl group transition-all hover:border-gray-200">
                    <div class="flex items-center gap-3.5">
                        <img src="${item.image}" class="w-[42px] h-[42px] rounded-xl object-cover shadow-sm">
                        <div>
                            <!-- ADDED: The visual label (Course or Indicator) -->
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">${item.type}</p>
                            <h4 class="text-[14px] font-bold text-gray-900 leading-tight">${item.title}</h4>
                            <p class="text-[12px] font-bold text-brand mt-0.5">$${item.price.toFixed(2)}</p>
                        </div>
                    </div>
                    <!-- ADDED: Pass product_section into removeFromCart -->
                    <button onclick="removeFromCart('${item.id}', ${item.product_section})" class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 hover:text-white hover:bg-red-500 transition-colors shadow-sm">
                        <i class="ph ph-trash text-lg"></i>
                    </button>
                </div>
            `;
        });
    }

    containers.forEach(container => container.innerHTML = htmlString);
    totalElements.forEach(el => el.innerText = `$${currentTotal.toFixed(2)}`);
}

        // --- LIBRARY LOGIC ---
        async function renderLibrary() {
            const token = localStorage.getItem('token');
            const contents = document.querySelectorAll('.lib-content');
            const emptyMsgs = document.querySelectorAll('.lib-empty-msg');

            if (!token) {
                contents.forEach(c => c.innerHTML = '<p class="text-sm text-gray-400 mt-4 text-center lib-empty-msg">Sign in to see your library.</p>');
                return;
            }

            try {
                const response = await fetch('/my-library', {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                if (!response.ok) throw new Error('Failed to load library');
                const data = await response.json();

                // Build course HTML
                let coursesHtml = '';
                if (data.courses && data.courses.length > 0) {
                    data.courses.forEach(course => {
                        const timerHtml = course.scheduled_at
                            ? `<div class="countdown-wrapper flex items-center gap-1 text-brand" data-scheduled="${course.scheduled_at}" data-duration="${course.estimated_duration || '2 hours'}">
                                 <i class="ph ph-clock font-bold text-xs"></i>
                                 <span class="timer-text text-xs font-bold">Calculating...</span>
                               </div>`
                            : `<div class="text-xs font-bold text-gray-400">Not scheduled</div>`;
                        coursesHtml += `
                            <div class="flex items-center justify-between p-3 bg-[#F8F9FB] border border-gray-100 rounded-2xl hover:border-gray-200 transition-all">
                                <div class="flex items-center gap-3 min-w-0">
                                    <img src="${course.thumbnail || 'https://via.placeholder.com/150'}" class="w-10 h-10 rounded-lg object-cover shadow-sm shrink-0">
                                    <div class="min-w-0">
                                        <p class="text-[13px] font-bold text-gray-900 truncate">${course.title}</p>
                                        <p class="text-[11px] text-gray-500 truncate">${course.description || 'No description'}</p>
                                    </div>
                                </div>
                                ${timerHtml}
                            </div>
                        `;
                    });
                } else {
                    coursesHtml = '<p class="text-sm text-gray-400 mt-4 text-center">No purchased courses yet.</p>';
                }

                // Build indicator HTML
                let indicatorsHtml = '';
                if (data.indicators && data.indicators.length > 0) {
                    data.indicators.forEach(ind => {
                        indicatorsHtml += `
                            <div class="flex items-center justify-between p-3 bg-[#F8F9FB] border border-gray-100 rounded-2xl hover:border-gray-200 transition-all">
                                <div class="flex items-center gap-3 min-w-0">
                                    <img src="${ind.thumbnail || 'https://via.placeholder.com/150'}" class="w-10 h-10 rounded-lg object-cover shadow-sm shrink-0">
                                    <div class="min-w-0">
                                        <p class="text-[13px] font-bold text-gray-900 truncate">${ind.name}</p>
                                        <p class="text-[11px] text-gray-500 truncate">${ind.description || 'No description'}</p>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                } else {
                    indicatorsHtml = '<p class="text-sm text-gray-400 mt-4 text-center">No purchased indicators yet.</p>';
                }

                // Build bot HTML
                let botsHtml = '';
                if (data.bots && data.bots.length > 0) {
                    data.bots.forEach(bot => {
                        botsHtml += `
                            <div class="flex items-center justify-between p-3 bg-[#F8F9FB] border border-gray-100 rounded-2xl hover:border-gray-200 transition-all">
                                <div class="flex items-center gap-3 min-w-0">
                                    <img src="${bot.thumbnail || 'https://via.placeholder.com/150'}" class="w-10 h-10 rounded-lg object-cover shadow-sm shrink-0">
                                    <div class="min-w-0">
                                        <p class="text-[13px] font-bold text-gray-900 truncate">${bot.name}</p>
                                        <p class="text-[11px] text-gray-500 truncate">${bot.description || 'No description'}</p>
                                    </div>
                                </div>
                            </div>
                        `;
                    });
                } else {
                    botsHtml = '<p class="text-sm text-gray-400 mt-4 text-center">No purchased alert bots yet.</p>';
                }

                // Store HTML in data attributes on each .lib-content container
                contents.forEach(container => {
                    container.dataset.courses = coursesHtml;
                    container.dataset.indicators = indicatorsHtml;
                    container.dataset.bots = botsHtml;
                });

                // Show currently active tab content
                const activeTab = document.querySelector('.lib-tab-courses.text-brand') ? 'courses'
                                : document.querySelector('.lib-tab-indicators.text-brand') ? 'indicators'
                                : 'bots';
                contents.forEach(container => {
                    container.innerHTML = container.dataset[activeTab];
                });

                forceTimerUpdate();
            } catch (err) {
                contents.forEach(c => c.innerHTML = '<p class="text-sm text-red-400 mt-4 text-center">Failed to load library.</p>');
            }
        }

        function switchLibTab(tab, btnElement) {
            const container = btnElement.closest('.slider-track') || btnElement.closest('.cart-widget-container');
            if (!container) return;

            const allTabs = container.querySelectorAll('[class*="lib-tab-"]');
            allTabs.forEach(t => {
                t.classList.remove('text-brand', 'border-brand');
                t.classList.add('text-gray-400', 'border-transparent');
            });
            btnElement.classList.remove('text-gray-400', 'border-transparent');
            btnElement.classList.add('text-brand', 'border-brand');

            const contents = container.querySelectorAll('.lib-content');
            contents.forEach(c => {
                c.innerHTML = c.dataset[tab] || '<p class="text-sm text-gray-400 mt-4 text-center">No items.</p>';
            });

            forceTimerUpdate();
        }

        // View Toggles and Animations
        function selectNav(element, event) {
            if (event) event.preventDefault();
            const navItems = document.querySelectorAll('.nav-item');
            navItems.forEach(item => {
                item.classList.remove('text-white', 'active');
                item.classList.add('text-gray-500', 'hover:bg-gray-50', 'hover:text-gray-900');
            });
            element.classList.remove('text-gray-500', 'hover:bg-gray-50', 'hover:text-gray-900');
            element.classList.add('text-white', 'active');

            const indicator = document.getElementById('nav-indicator');
            if (indicator) {
                indicator.style.top = element.offsetTop + 'px';
                indicator.style.height = element.offsetHeight + 'px';
            }
        }

        function toggleLike(button, event) {
            event.stopPropagation();
            button.classList.toggle('active');
            button.style.transform = 'scale(0.9)';
            setTimeout(() => { button.style.transform = 'scale(1)'; }, 100);
        }

        function switchSlide(slide, btnElement) {
            const container = btnElement.closest('.cart-widget-container');
            const track = container.querySelector('.slider-track');
            const tabLibrary = container.querySelector('.tab-library');
            const tabCart = container.querySelector('.tab-cart');

            if (slide === 'library') {
                track.style.transform = 'translateX(0)';
                tabLibrary.classList.remove('text-gray-400', 'border-transparent');
                tabLibrary.classList.add('text-gray-900', 'border-brand');
                tabCart.classList.remove('text-gray-900', 'border-brand');
                tabCart.classList.add('text-gray-400', 'border-transparent');
            } else if (slide === 'cart') {
                track.style.transform = 'translateX(-50%)';
                tabCart.classList.remove('text-gray-400', 'border-transparent');
                tabCart.classList.add('text-gray-900', 'border-brand');
                tabLibrary.classList.remove('text-gray-900', 'border-brand');
                tabLibrary.classList.add('text-gray-400', 'border-transparent');
            }
        }

        function openModal() {
            const overlay = document.getElementById('cart-modal-overlay');
            const content = document.getElementById('cart-modal-content');
            overlay.classList.remove('hidden');
            void overlay.offsetWidth; 
            overlay.classList.remove('opacity-0');
            overlay.classList.add('opacity-100');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
            const targetTab = cartState.length > 0 ? 'cart' : 'library';
            switchSlide(targetTab, document.querySelector(`#cart-modal-content .tab-${targetTab}`));
        }

        function closeModal() {
            const overlay = document.getElementById('cart-modal-overlay');
            const content = document.getElementById('cart-modal-content');
            overlay.classList.remove('opacity-100');
            overlay.classList.add('opacity-0');
            content.classList.remove('scale-100');
            content.classList.add('scale-95');
            setTimeout(() => { overlay.classList.add('hidden'); }, 300);
        }

        function closeModalOnOverlay(event) {
            if (event.target === event.currentTarget) closeModal();
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                const productOverlay = document.getElementById('product-modal-overlay');
                if (productOverlay && !productOverlay.classList.contains('hidden')) {
                    closeProductPage();
                }
                const cartOverlay = document.getElementById('cart-modal-overlay');
                if (cartOverlay && !cartOverlay.classList.contains('hidden')) {
                    closeModal();
                }
            }
        });
    </script>

    <!-- Mobile Bottom Navigation -->
    <nav class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-100 z-40 flex md:hidden justify-around items-center h-[72px]">
        <a href="/courses" class="mobile-nav-item flex flex-col items-center justify-center gap-1 w-full h-full text-brand active" onclick="navigateTo(event, 'courses')">
            <i class="ph ph-graduation-cap text-2xl"></i>
            <span class="text-[10px] font-semibold">Courses</span>
        </a>
        <a href="/indicators" class="mobile-nav-item flex flex-col items-center justify-center gap-1 w-full h-full text-gray-400" onclick="navigateTo(event, 'indicators')">
            <i class="ph ph-chart-line-up text-2xl"></i>
            <span class="text-[10px] font-semibold">Indicators</span>
        </a>
        <a href="/alerts" class="mobile-nav-item flex flex-col items-center justify-center gap-1 w-full h-full text-gray-400" onclick="navigateTo(event, 'alerts')">
            <i class="ph ph-bell-ringing text-2xl"></i>
            <span class="text-[10px] font-semibold">Alerts</span>
        </a>
        <a href="/settings" class="mobile-nav-item flex flex-col items-center justify-center gap-1 w-full h-full text-gray-400" onclick="navigateTo(event, 'settings')">
            <i class="ph ph-gear text-2xl"></i>
            <span class="text-[10px] font-semibold">Settings</span>
        </a>
    </nav>

    <!-- Toast Container -->
    <div id="toast-container" class="fixed top-5 right-5 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

    <style>
        .toast {
            pointer-events: auto;
            min-width: 300px;
            max-width: 420px;
            padding: 14px 18px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
            font-weight: 600;
            box-shadow: 0 10px 40px rgba(0,0,0,0.12);
            transform: translateX(120%);
            transition: transform 0.35s cubic-bezier(0.21,1.02,0.73,1), opacity 0.3s ease;
            opacity: 0;
        }
        .toast.show {
            transform: translateX(0);
            opacity: 1;
        }
        .toast.hide {
            transform: translateX(120%);
            opacity: 0;
        }
        .toast-success {
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            color: #166534;
        }
        .toast-error {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
        }
        .toast-icon {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 16px;
        }
        .toast-success .toast-icon { background: #dcfce7; color: #16a34a; }
        .toast-error .toast-icon { background: #fee2e2; color: #dc2626; }
        .toast-msg { flex: 1; line-height: 1.4; }
        .toast-close {
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            border-radius: 8px;
            opacity: 0.5;
            transition: opacity 0.2s;
            flex-shrink: 0;
        }
        .toast-close:hover { opacity: 1; }
        .error-highlight {
            border: 2px solid #ef4444 !important;
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15) !important;
            animation: pulse-red 2s ease-in-out 3;
        }
        @keyframes pulse-red {
            0%, 100% { box-shadow: 0 0 0 3px rgba(239,68,68,0.15); }
            50% { box-shadow: 0 0 0 6px rgba(239,68,68,0.08); }
        }
    </style>
</body>
</html>
