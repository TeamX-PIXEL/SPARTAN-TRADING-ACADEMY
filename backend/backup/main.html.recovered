            let user = null;
            if (token) {
                try {
                    const res = await fetch('/users/me', { headers: { 'Authorization': 'Bearer ' + token } });
                    if (res.ok) user = await res.json();
                } catch (e) { console.error("Failed to load user profile"); }
            }

            const highlightField = errorField || '';
            const tvidHighlight = highlightField === 'tvid' ? 'error-highlight' : '';

            actualCards.innerHTML = `
                <div class="col-span-full flex flex-col gap-3 max-w-2xl mx-auto w-full">
