import { DataTable } from "./_components/recent-leads-table/table";
import { tableDataSchema, type TableDataRow } from "./_components/recent-leads-table/schema";
import { z } from "zod";

const tableDataArraySchema = z.array(tableDataSchema);

async function getUsers(): Promise<TableDataRow[]> {
  try {
    // 1. Fetch with your exact Python Authorization Header
    const res = await fetch("http://127.0.0.1:8000/api/users", {
      cache: "no-store",
      headers: {
        "Authorization": "Bearer spartan_api_key_2026_secure", 
        "Content-Type": "application/json"
      }
    });

    if (!res.ok) {
      throw new Error(`Backend returned status: ${res.status}`);
    }

    // 2. Parse the Python JSON dictionary
    const rawData = await res.json();

    if (!rawData.success) {
      throw new Error(rawData.message || "Backend reported failure");
    }

    // 3. Map your Database columns to the Frontend Table schema
    const formattedData = rawData.users.map((dbUser: any) => {
      
      // Determine which model is currently active to display in the table.
      // Prioritizing Alpha, then Evergreen, then Legacy.
      let activeModel = "None";
      let activeExpiry = "N/A";

      if (dbUser.Evergreen_Expiry) { activeModel = "Evergreen"; activeExpiry = dbUser.Evergreen_Expiry; }
      if (dbUser.Legacy_Expiry) { activeModel = "Legacy"; activeExpiry = dbUser.Legacy_Expiry; }
      if (dbUser.Alpha_Expiry) { activeModel = "Alpha"; activeExpiry = dbUser.Alpha_Expiry; }

      return {
        id: String(dbUser.id || "N/A"), 
        key: dbUser.user_key || "No Key", // <-- FIXED: Pointing to your DB's actual column name
        user: dbUser.user || "Null",   // <-- Maps to the @username
        telegramId: String(dbUser.telegram_id || "Null"), // <-- Maps to the numeric ID
        model: activeModel,
        expiry: activeExpiry,
      };

    });

    // 4. Validate the mapped data
    const validatedData = tableDataArraySchema.parse(formattedData);

    return validatedData;

  } catch (error) {
    console.error("Failed to fetch or validate users:", error);
    return []; 
  }
}

export default async function Page() {
  const data = await getUsers();

  return (
    <div className="flex flex-col gap-4 md:gap-6 p-4">
      <DataTable data={data} />
    </div>
  );
}
