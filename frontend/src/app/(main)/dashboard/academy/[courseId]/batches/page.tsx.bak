import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { BatchesTable } from "@/app/(main)/dashboard/academy/_components/batches-table";
import { ChaptersTable } from "@/app/(main)/dashboard/academy/_components/chapters-table";
import type { BatchRow } from "@/app/(main)/dashboard/academy/_components/batches-schema";
import type { ChapterRow } from "@/app/(main)/dashboard/academy/_components/chapters-columns";

// 1. Fetch the Batches
async function getBatchesForCourse(courseId: string): Promise<BatchRow[]> {
  try {
    const res = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/courses/${courseId}/batches`, {
      cache: "no-store",
    });
    
    if (!res.ok) return [];
    const backendData = await res.json();

    return backendData.map((batch: any) => {
      const startDate = new Date(batch.batch_start_date);
      const endDate = new Date(startDate);
      endDate.setDate(endDate.getDate() + batch.max_days);

      const now = new Date();
      let status = "Scheduled";
      if (now > endDate) status = "Finished";
      else if (now >= startDate) status = "Ongoing";

      return {
        id: batch.id,
        batchId: `B-${batch.id}`, 
        batchName: startDate.toLocaleDateString("en-US", { month: "long", year: "numeric" }),
        startDate: startDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }),
        endDate: endDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }),
        status: status,
        participants: batch.min_enroll,
        chaptersFinished: 0, 
        totalChapters: 12,   
        rawStartDate: batch.batch_start_date, // Needed for the Edit popup!
        maxDays: batch.max_days,              // Needed for the Edit popup!
      };
    });
  } catch (error) {
    console.error("Error fetching batches:", error);
    return [];
  }
}
async function getChaptersForCourse(courseId: string): Promise<ChapterRow[]> {
  try {
    const res = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/courses/${courseId}/chapters`, {
      cache: "no-store",
    });
    
    if (!res.ok) return [];
    const backendData = await res.json();

    return backendData.map((chap: any) => ({
      id: `chap-${chap.id}`, // dnd-kit requires string IDs
      dbId: chap.id, // We store the real DB integer for our PUT/DELETE API calls
      name: chap.title,
      day: chap.days_after_start,
      index: chap.chapter_index,
    }));
  } catch (error) {
    console.error("Error fetching chapters:", error);
    return [];
  }
}
// 2. NEW: Fetch the actual Course Name from your database
async function getCourseName(courseId: string): Promise<string> {
  try {
    const res = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/courses`, {
      cache: "no-store",
    });
    
    if (!res.ok) return `Course ${courseId}`;
    
    const courses = await res.json();
    // Find the course where the ID matches the one in our URL
    const course = courses.find((c: any) => c.id.toString() === courseId);
    
    return course ? course.title : `Course ${courseId}`;
  } catch (error) {
    console.error("Error fetching course name:", error);
    return `Course ${courseId}`;
  }
}

async function getBatchTemplate(courseId: string) {
  try {
    const res = await fetch(`${process.env.NEXT_PUBLIC_API_URL}/courses/${courseId}/template`, { cache: "no-store" });
    if (!res.ok) return null;
    return await res.json();
  } catch (error) {
    console.error("Error fetching template:", error);
    return null;
  }
}
const initialChapters: ChapterRow[] = [
  { id: "chap-1", name: "Introduction and Setup", day: 1 },
  { id: "chap-2", name: "Core Concepts", day: 5 },
  { id: "chap-3", name: "Advanced Techniques", day: 10 },
  { id: "chap-4", name: "Final Assessment Project", day: 14 },
];

export default async function CourseManagementPage({ params }: { params: Promise<{ courseId: string }> }) {
  const { courseId } = await params;
  
  // 3. Await both database calls
  const realBatchData = await getBatchesForCourse(courseId);
  const realCourseName = await getCourseName(courseId); // Get the real name!
  const realChapterData = await getChaptersForCourse(courseId);
  const templateData = await getBatchTemplate(courseId); 

  return (
    <div className="p-6">
      <div className="mb-6">
        <h2 className="text-3xl font-bold tracking-tight">Course Management</h2>
        <p className="mt-2 text-sm text-muted-foreground">
          Manage your course catalog and organize the shared curriculum chapters.
        </p>
      </div>

      <Tabs defaultValue="batches" className="w-full">
        <TabsList className="mb-4">
          <TabsTrigger value="batches">Batches</TabsTrigger>
          <TabsTrigger value="chapters">Chapters</TabsTrigger>
        </TabsList>

        <TabsContent value="batches">
          {/* 4. Pass the real name into the table! */}
          <BatchesTable 
            data={realBatchData} 
            courseId={courseId} 
            courseName={realCourseName} 
          />
        </TabsContent>

                <TabsContent value="chapters">
          <div className="rounded-md border bg-card text-card-foreground shadow">
            <div className="p-6">
              <ChaptersTable initialData={realChapterData} courseId={courseId} />
            </div>
          </div>
        </TabsContent>

      </Tabs>
    </div>
  );
}
